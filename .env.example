# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI provider order: groq,github
AI_PROVIDER_ORDER=groq,github
GROQ_API_KEY=
MODEL_NAME=llama-3.3-70b-versatile
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# Market data polling
CHECK_INTERVAL_MINUTES=60
NEWS_LOOKBACK_DAYS=7
MAX_NEWS_ITEMS=5

# Dynamic ticker discovery
DAY_GAINERS_LIMIT=10
MOST_ACTIVE_LIMIT=10
TRENDING_NEWS_LIMIT=25
DISCOVERY_REGION=US
DISCOVERY_CACHE_MINUTES=360
MAX_AI_CANDIDATES=3
MIN_SIGNAL_PRICE_CHANGE_PCT=1.0
MIN_SIGNAL_RELATIVE_VOLUME=1.2
REQUEST_TIMEOUT_SECONDS=12
MAX_PARALLEL_TICKERS=1

# Alpaca paper trading
PAPER_TRADING_ENABLED=false
PAPER_TRADING_DRY_RUN=true
PAPER_MIN_CONFIDENCE=75
PAPER_MAX_OPEN_POSITIONS=3
PAPER_MAX_POSITIONS=3
PAPER_MAX_POSITION_PCT=10.0
PAPER_MAX_TRADES_PER_DAY=3
PAPER_MAX_TRADES_PER_TICKER_PER_DAY=1
PAPER_ALLOW_SHORTS=false
PAPER_ALLOW_OPTIONS=false
PAPER_SIGNAL_FILE=signals.jsonl
PAPER_TRADE_LOG=paper_trades.jsonl
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Runtime
LOG_LEVEL=INFO
STATE_FILE=state.json
TIMEZONE=UTC
