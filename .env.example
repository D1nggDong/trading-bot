# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub Copilot / AI
COPILOT_MODEL=claude-3.5-sonnet
GITHUB_TOKEN=
MODEL_NAME=gpt-4o

# Market data polling
CHECK_INTERVAL_MINUTES=60
NEWS_LOOKBACK_DAYS=7
MAX_NEWS_ITEMS=5

# Dynamic ticker discovery (no static ticker list)
DAY_GAINERS_LIMIT=10
MOST_ACTIVE_LIMIT=10
TRENDING_NEWS_LIMIT=25
DISCOVERY_REGION=US
REQUEST_TIMEOUT_SECONDS=12
MAX_PARALLEL_TICKERS=1

# Runtime
LOG_LEVEL=INFO
STATE_FILE=state.json
TIMEZONE=UTC
